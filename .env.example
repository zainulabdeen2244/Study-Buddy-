# Study-Buddy AI runtime
PORT=7860
STUDY_BUDDY_DEFAULT_COLLECTION=study-buddy-demo
FORGE_VIDEO_RAG_DATA_DIR=.data/study-buddy/video-rag
FORGE_VIDEO_RAG_REAL_PROVIDERS=false
FORGE_VIDEO_RAG_STORE=json
FORGE_VIDEO_RAG_EMBED_DIMS=384

# Optional LLM answer composer. Evidence-first deterministic mode works without keys.
STUDY_BUDDY_USE_LLM=false
STUDY_BUDDY_ORCHESTRATOR_LLM=false
STUDY_BUDDY_LLM_PROVIDER=openai
STUDY_BUDDY_LLM_MODEL=gpt-4.1-mini
STUDY_BUDDY_LLM_MAX_TOKENS=900
STUDY_BUDDY_LLM_BASE_URL=
STUDY_BUDDY_LLM_API_KEY=

# Provider-specific keys. Use one provider at a time.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
OPENROUTER_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MOONSHOT_API_KEY=
